<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location Tracking Mode"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/locationModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <RadioButton
                android:id="@+id/radioGps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pure GPS (High Power)" />

            <RadioButton
                android:id="@+id/radioNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Network Provider (Low Power)" />

            <RadioButton
                android:id="@+id/radioGoogleBalanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Google Fused: Balanced Power" />

            <RadioButton
                android:id="@+id/radioGooglePassiveSmart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Google Fused: Smart Passive" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Period (ms)"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editUpdatePeriod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 60000" />
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passive Freshness Threshold (ms)"
            android:textStyle="bold"
            android:paddingTop="8dp"/>
        <EditText
            android:id="@+id/editFreshness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 600000" />
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passive Accuracy Threshold (meters)"
            android:textStyle="bold"
            android:paddingTop="8dp"/>
        <EditText
            android:id="@+id/editAccuracy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="e.g. 1000.0" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Save Settings" />

        <Button
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Sign out" />
            
    </LinearLayout>
</ScrollView>